{
  "description": "Blocks writes/edits while on the main or master branch — forces a feature branch.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/block-main-branch-changes.sh\""
          }
        ]
      }
    ]
  }
}
