{
  "description": "Blocks writes/edits that introduce hardcoded secrets or credentials.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scan-for-secrets.sh\""
          }
        ]
      }
    ]
  }
}
